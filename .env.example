# ============================================================
# MyVlessBot — Шаблон конфигурации (.env.example)
# Скопируйте в .env и заполните своими значениями
# ============================================================

# --- Обязательные ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ADMIN_TELEGRAM_ID=123456789
DOMAIN=yourdomain.com

# --- 3x-ui панель ---
PANEL_LOGIN=admin
PANEL_PASSWORD=your_panel_password

# --- База данных ---
# DB_PATH=./users.db  # Путь по умолчанию

# --- Поддержка (опционально) ---
# SUPPORT_BOT_TOKEN=your_support_bot_token
# TELEGRAM_BOT_USERNAME=your_bot_username

# --- YooKassa ---
# YOOKASSA_ENABLED=false
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=

# --- CryptoBot ---
# CRYPTOBOT_ENABLED=false
# CRYPTOBOT_TOKEN=
# CRYPTOBOT_WEBHOOK_SECRET=

# --- Heleket ---
# HELEKET_ENABLED=false
# HELEKET_MERCHANT_ID=
# HELEKET_API_KEY=

# --- TON Connect ---
# TONCONNECT_ENABLED=false
# TON_WALLET_ADDRESS=
# TONAPI_KEY=
